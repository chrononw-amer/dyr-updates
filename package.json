{
  "name": "dyr",
  "version": "1.8.33",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:build": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.chrono.realestate",
    "productName": "DYR",
    "copyright": "Copyright ط¢آ© 2026 DYR",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/assets",
        "to": "assets",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "electron/assets/icon.ico",
      "artifactName": "DYR-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DYR",
      "include": "build/installer.nsh"
    },
    "directories": {
      "output": "release",
      "buildResources": "electron/assets"
    },
    "publish": {
      "provider": "github",
      "owner": "chrononw-amer",
      "repo": "dyr-updates"
    }
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.0.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@ionic/react": "^8.7.17",
    "@ionic/react-router": "^8.7.17",
    "@supabase/supabase-js": "^2.94.0",
    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "ionicons": "^8.0.13",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/ios": "^8.0.2",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "body-parser": "^2.2.2",
    "concurrently": "^9.2.1",
    "electron": "^34.5.8",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "javascript-obfuscator": "^5.4.1",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "rollup-plugin-obfuscator": "^1.1.0",
    "sharp": "^0.34.5",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}
